# Root env (preencha com seus dados do Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
# Recomendado para carga alta: URL pooler (PgBouncer) do Supabase
DATABASE_URL=

# Backend tuning
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_POOL_MAX_USES=7500
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute
# Em producao, manter false e aplicar migrations via SQL.
RUN_STARTUP_PATCHES=false

# Portas do CRM-Hausecare
CRM_BACKEND_PORT=4010
CRM_FRONTEND_PORT=3010
